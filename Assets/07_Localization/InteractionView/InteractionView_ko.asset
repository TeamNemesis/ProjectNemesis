      m_Items:
      - rid: 5530781212759556100
  - m_Id: 2
    m_Localized: "\uC77C\uBC18 \uBC29"
    m_Metadata:
      m_Items:
      - rid: 5530781212759556101
  - m_Id: 12
    m_Localized: "\uC801\uB4E4\uC744 \uBB3C\uB9AC\uCE58\uACE0 \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD558\uC138\uC694!"
    m_Metadata:
      m_Items:
      - rid: 5530781212759556102
  - m_Id: 3
    m_Localized: "\uC2E4\uD5D8\uC2E4"
    m_Metadata:
      m_Items:
      - rid: 5530781212759556103
  - m_Id: 13
    m_Localized: "\uC2E4\uD5D8\uC2E4: \uC2E4\uD5D8 \uC7A5\uBE44\uC640 \uD568\uC815\uC774
      \uC874\uC7AC\uD569\uB2C8\uB2E4. \uC8FC\uC758\uD574\uC11C \uC9C4\uD589\uD558\uC138\uC694!"
    m_Metadata:
      m_Items:
      - rid: 5530781212759556104
  - m_Id: 4
    m_Localized: "\uD22C\uAE30\uC7A5"
    m_Metadata:
      m_Items:
      - rid: 5530781212759556105
  - m_Id: 14
    m_Localized: "\uD22C\uAE30\uC7A5: \uC5F0\uC18D \uC804\uD22C\uC5D0 \uB3C4\uC804\uD558\uC5EC
      \uB354 \uB192\uC740 \uBCF4\uC0C1\uC744 \uD68D\uB4DD\uD558\uC138\uC694!"
    m_Metadata:
      m_Items:
      - rid: 5530781212759556106
  - m_Id: 5
    m_Localized: "\uC0C1\uC810"
    m_Metadata:
      m_Items:
      - rid: 5530781212759556107
  - m_Id: 15
    m_Localized: "\uD06C\uB808\uB527\uC744 \uC0AC\uC6A9\uD558\uC5EC \uBCF4\uC0C1\uC744
      \uAD6C\uB9E4\uD558\uC138\uC694!"
    m_Metadata:
      m_Items:
      - rid: 5530781212759556108
  - m_Id: 6
    m_Localized: "\uBCF4\uC2A4 \uBC29"
    m_Metadata:
      m_Items:
      - rid: 5530781212759556109
  - m_Id: 16
    m_Localized: "\uBCF4\uC2A4 \uBC29: \uAC15\uB825\uD55C \uC801\uC774 \uAE30\uB2E4\uB9BD\uB2C8\uB2E4.
      \uC804\uB7B5\uC744 \uC138\uC6CC \uB3C4\uC804\uD558\uC138\uC694!"
    m_Metadata:
      m_Items:
      - rid: 5530781212759556110
  - m_Id: 21
    m_Localized: "\uD06C\uB808\uB527"
    m_Metadata:
      m_Items:
      - rid: 5530781212759556315
  - m_Id: 22
    m_Localized: "\uAC8C\uC784 \uB0B4 \uD654\uD3D0\uC785\uB2C8\uB2E4. \uC0C1\uC810\uC5D0\uC11C
      \uC544\uC774\uD15C\uC774\uB098 \uBCF4\uC0C1\uC744 \uAD6C\uB9E4\uD558\uB294
      \uB370 \uC0AC\uC6A9\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items:
      - rid: 5530781212759556316
  - m_Id: 23
    m_Localized: "\uD06C\uB86C"
    m_Metadata:
      m_Items:
      - rid: 5530781212759556317
  - m_Id: 24
    m_Localized: "\uD06C\uB86C: \uC7A5\uBE44 \uC5C5\uADF8\uB808\uC774\uB4DC\uB098
      \uC81C\uC791\uC5D0 \uC0AC\uC6A9\uB418\uB294 \uD76C\uADC0 \uC790\uC6D0\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items:
      - rid: 5530781212759556318
  - m_Id: 25
    m_Localized: "\uD68C\uBCF5 \uD329"
    m_Metadata:
      m_Items:
      - rid: 5530781212759556319
  - m_Id: 26
    m_Localized: "\uC0AC\uC6A9 \uC2DC \uC989\uC2DC \uCCB4\uB825\uC744 \uD68C\uBCF5\uD569\uB2C8\uB2E4.
      \uD68C\uBCF5\uB7C9\uC740 \uC7A5\uBE44\uC5D0 \uB530\uB77C \uB2EC\uB77C\uC9D1\uB2C8\uB2E4."
    m_Metadata:
      m_Items:
      - rid: 5530781212759556320
  - m_Id: 27
    m_Localized: "\uAE30\uC220\uD329 (\uD68C\uC0AC1)"
    m_Metadata:
      m_Items:
      - rid: 5530781212759556321
  - m_Id: 28
    m_Localized: "\uC774 \uD329\uC744 \uD68D\uB4DD\uD558\uBA74 \uD68C\uC0AC1\uC758
      \uAE30\uC220 \uC911 \uD558\uB098\uB97C \uC120\uD0DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
