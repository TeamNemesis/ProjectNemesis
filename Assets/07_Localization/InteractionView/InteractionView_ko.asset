      - rid: 5530781212759556330
  - m_Id: 37
    m_Localized: "\uAE30\uC220 \uC5C5\uADF8\uB808\uC774\uB4DC \uD329"
    m_Metadata:
      m_Items:
      - rid: 5530781212759556331
  - m_Id: 38
    m_Localized: "\uAE30\uC220\uC758 \uC131\uB2A5\uC744 \uAC15\uD654\uD558\uAC70\uB098
      \uC5C5\uADF8\uB808\uC774\uB4DC\uD560 \uC218 \uC788\uB294 \uC7AC\uB8CC\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items:
      - rid: 5530781212759556332
  - m_Id: 39
    m_Localized: "\uB3CC\uC5F0\uBCC0\uC774 \uD329"
    m_Metadata:
      m_Items:
      - rid: 5530781212759556333
  - m_Id: 40
    m_Localized: "\uB3CC\uC5F0\uBCC0\uC774 \uAD00\uB828 \uBCF4\uC0C1\uC785\uB2C8\uB2E4.
      \uB79C\uB364 \uB2A5\uB825 \uB610\uB294 \uB3CC\uC5F0\uBCC0\uC774 \uC7AC\uB8CC\uB97C
      \uD3EC\uD568\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items:
      - rid: 5530781212759556334
  references:
    version: 2
    RefIds:
    - rid: 5530781212759556099
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uB9F5\uACFC \uBC29 \uBAA9\uB85D\uC5D0 \uD45C\uC2DC\uB418\uB294
          \uC9E7\uC740 \uC81C\uBAA9\uC785\uB2C8\uB2E4. \uBAA8\uBC14\uC77C\uC5D0\uC11C\uB3C4
          \uD55C \uC904\uB85C \uBCF4\uC774\uB3C4\uB85D 20\uC790 \uC774\uB0B4\uB85C
          \uC791\uC131\uD558\uC138\uC694."
    - rid: 5530781212759556100
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uBC29 \uC0C1\uC138 \uC815\uBCF4\uC5D0 \uD45C\uC2DC\uB429\uB2C8\uB2E4.
          \uC804\uD22C \uC900\uBE44\uB97C \uC548\uB0B4\uD558\uB294 \uBB38\uC7A5\uC73C\uB85C,
          \uBAA8\uBC14\uC77C\uC5D0\uC11C \uC904\uBC14\uAFC8\uB420 \uC218 \uC788\uC73C\uB2C8
          120\uC790 \uC774\uB0B4\uB85C \uC791\uC131\uD558\uC138\uC694."
    - rid: 5530781212759556101
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uB9F5/\uBAA9\uB85D\uC5D0 \uBCF4\uC774\uB294 \uC9E7\uC740
          \uC81C\uBAA9\uC785\uB2C8\uB2E4. 20\uC790 \uC774\uB0B4\uB85C \uC720\uC9C0\uD558\uC138\uC694."
    - rid: 5530781212759556102
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uBAA9\uD45C(\uC608: \uC801 \uCC98\uCE58)\uB97C \uAC04\uB2E8\uD788
          \uC124\uBA85\uD558\uC138\uC694. \uBAA8\uBC14\uC77C\uC5D0\uC11C \uBCF4\uC774\uB294
          \uAE38\uC774\uB97C \uACE0\uB824\uD574 120\uC790 \uC774\uB0B4\uB85C."
    - rid: 5530781212759556103
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uC2E4\uD5D8/\uAE30\uACC4 \uAD00\uB828 \uBC29\uC744 \uB098\uD0C0\uB0B4\uB294
          \uC9E7\uC740 \uC81C\uBAA9\uC785\uB2C8\uB2E4. 20\uC790 \uC774\uB0B4 \uAD8C\uC7A5."
    - rid: 5530781212759556104
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uD2B9\uC218 \uD6A8\uACFC\uB098 \uD568\uC815 \uB4F1 \uC8FC\uC758\uC0AC\uD56D\uC744
          \uD3EC\uD568\uD558\uC138\uC694. \uBAA8\uBC14\uC77C \uD45C\uC2DC \uAE38\uC774(\uC57D
          120\uC790) \uACE0\uB824."
    - rid: 5530781212759556105
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uC5F0\uC18D \uC804\uD22C/\uB300\uC804 \uD615\uC2DD\uC758
          \uBC29\uC744 \uB098\uD0C0\uB0C5\uB2C8\uB2E4. \uC9E7\uAC8C \uD45C\uAE30(20\uC790
          \uC774\uB0B4)."
    - rid: 5530781212759556106
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uC5F0\uC18D \uC804\uD22C \uD615\uC2DD\uACFC \uBCF4\uC0C1
          \uAD00\uB828 \uC124\uBA85\uC744 \uAC04\uACB0\uD558\uAC8C \uC801\uC73C\uC138\uC694.
          \uBAA8\uBC14\uC77C \uD45C\uC2DC \uAE38\uC774 \uC720\uC758."
    - rid: 5530781212759556107
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "UI \uBC84\uD2BC/\uBAA9\uB85D\uC5D0 \uD45C\uC2DC\uB418\uB294
          \uC81C\uBAA9\uC785\uB2C8\uB2E4. \uAC00\uB2A5\uD558\uBA74 \uD55C \uB2E8\uC5B4\uB85C,
          \uAE38\uC774 \uC81C\uD55C(\uBAA8\uBC14\uC77C) \uACE0\uB824."
    - rid: 5530781212759556108
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uAD6C\uB9E4 \uBC29\uC2DD(\uC608: \uD06C\uB808\uB527 \uC0AC\uC6A9)\uC744
          \uBA85\uD655\uD788 \uC801\uC73C\uC138\uC694. \uBAA8\uBC14\uC77C \uB808\uC774\uC544\uC6C3\uC744
          \uACE0\uB824\uD574 120\uC790 \uC774\uB0B4\uB85C."
    - rid: 5530781212759556109
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uBCF4\uC2A4 \uC804\uD22C\uAC00 \uBC1C\uC0DD\uD558\uB294
          \uBC29 \uC81C\uBAA9\uC785\uB2C8\uB2E4. \uC911\uC694\uB3C4\uB97C \uB098\uD0C0\uB0B4\uBBC0\uB85C
          \uBA85\uD655\uD558\uAC8C \uD45C\uAE30(20\uC790 \uC774\uB0B4)."
    - rid: 5530781212759556110
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uB09C\uC774\uB3C4 \uACBD\uACE0\uC640 \uC900\uBE44 \uAD8C\uACE0\uB97C
          \uD3EC\uD568\uD558\uC138\uC694. \uBAA8\uBC14\uC77C\uC5D0\uC11C \uC904\uBC14\uAFC8\uC744
          \uACE0\uB824\uD574 120\uC790 \uC774\uB0B4\uB85C \uC791\uC131."
    - rid: 5530781212759556315
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uD654\uD3D0 \uB2E8\uC704\uB85C UI\uC5D0 \uC9E7\uAC8C \uD45C\uC2DC\uB429\uB2C8\uB2E4.
          \uC22B\uC790\uC640 \uD568\uAED8 \uC4F0\uC9C0 \uB9C8\uC138\uC694."
    - rid: 5530781212759556316
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uAD6C\uB9E4 \uC6A9\uB3C4\uC640 \uC0AC\uC6A9\uCC98\uB97C
          \uAC04\uB2E8\uD788 \uC124\uBA85\uD558\uC138\uC694. \uBAA8\uBC14\uC77C\uC5D0\uC11C
          \uC904\uBC14\uAFC8\uB420 \uC218 \uC788\uC73C\uB2C8 120\uC790 \uC774\uB0B4\uB85C."
    - rid: 5530781212759556317
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uC790\uC6D0 \uBA85\uCE6D(\uC9E7\uAC8C). UI \uB808\uC774\uC544\uC6C3\uC5D0
          \uB9DE\uAC8C 12\uC790 \uC774\uB0B4 \uAD8C\uC7A5."
    - rid: 5530781212759556318
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uC790\uC6D0 \uC0AC\uC6A9\uCC98(\uC5C5\uADF8\uB808\uC774\uB4DC/\uC81C\uC791
          \uB4F1)\uB97C \uAC04\uB2E8\uD788 \uBA85\uC2DC\uD558\uC138\uC694. 120\uC790
          \uC774\uB0B4 \uAD8C\uC7A5."
    - rid: 5530781212759556319
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uC9E7\uC740 \uC18C\uBAA8\uD488 \uC774\uB984. UI \uD45C\uC2DC\uB97C
          \uACE0\uB824\uD574 12\uC790 \uC774\uB0B4 \uAD8C\uC7A5."
    - rid: 5530781212759556320
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uD6A8\uACFC \uC694\uC57D(\uC989\uC2DC \uD68C\uBCF5 \uB4F1).
          \uC815\uD655\uD55C \uC218\uCE58\uB294 \uBCC4\uB3C4 \uD45C\uAE30 \uC2DC
          \uC548\uB0B4\uD558\uC138\uC694."
    - rid: 5530781212759556321
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uD68C\uC0AC\uC758 \uC774\uB984 \uD45C\uAE30 \uBC29\uC2DD
          \uC77C\uAD00\uC131 \uC720\uC9C0. UI \uC5EC\uC720\uAC00 \uC5C6\uC73C\uBA74
          '\uAE30\uC220\uD329'\uB9CC \uC0AC\uC6A9."
    - rid: 5530781212759556322
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uC120\uD0DD\uD615 \uBCF4\uC0C1\uC784\uC744 \uBA85\uD655\uD788
          \uD45C\uAE30\uD558\uC138\uC694. \uBAA8\uBC14\uC77C \uD45C\uC2DC \uAE38\uC774
          \uACE0\uB824."
    - rid: 5530781212759556323
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uD68C\uC0AC\uBA85 \uD45C\uAE30 \uBC29\uC2DD \uC77C\uAD00\uC131
          \uC720\uC9C0."
    - rid: 5530781212759556324
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\uC120\uD0DD\uD615 \uBCF4\uC0C1\uC784\uC744 \uBA85\uD655\uD788.
