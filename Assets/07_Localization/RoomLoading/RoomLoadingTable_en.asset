  m_TableData:
  - m_Id: 51
    m_Localized: 'There are the following room types: Laboratory, Normal Combat Room,
      Black Market, Colosseum, and Boss Combat Room.'
    m_Metadata:
      m_Items:
      - rid: 5530781231432073408
  - m_Id: 52
    m_Localized: "The Mutant Orb is Nebulasa\u2019s secret technology, and it caused
      the Second Corporation War."
    m_Metadata:
      m_Items:
      - rid: 5530781231432073409
  - m_Id: 53
    m_Localized: There are five corporations, and each corporation provides technology
      with a unique concept.
    m_Metadata:
      m_Items:
      - rid: 5530781231432073410
  - m_Id: 54
    m_Localized: Technologies that directly enhance Basic Attack, Dash, Special Attack,
      or Grenade are mutually exclusive and will be replaced when you acquire another
      such technology.
    m_Metadata:
      m_Items:
      - rid: 5530781231432073411
  - m_Id: 55
    m_Localized: You hate Nebulasa with a burning fury.
    m_Metadata:
      m_Items:
      - rid: 5530781231432073412
  references:
    version: 2
    RefIds:
    - rid: 5530781231432073408
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: Shown randomly during loading; briefly describe room types.
          Keep within ~120 chars.
    - rid: 5530781231432073409
